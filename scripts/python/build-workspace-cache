#!/usr/bin/env python3
"""Capture workspace preview screenshots for all outputs."""
# Imports
import subprocess
import sys
import json
import os
from pathlib import Path

# Screenshot cache directory
THUMB_DIR = Path.home() / ".cache/piixident/workspace/thumbs"

def main():
    THUMB_DIR.mkdir(parents=True, exist_ok=True)

    # Query niri for outputs
    try:
        result = subprocess.run(
            ["niri", "msg", "--json", "outputs"],
            capture_output=True, text=True, timeout=5
        )
        outputs = json.loads(result.stdout)
    except Exception as e:
        print(f"error:Failed to get outputs: {e}", flush=True)
        return

    # Query niri for workspaces
    try:
        result = subprocess.run(
            ["niri", "msg", "--json", "workspaces"],
            capture_output=True, text=True, timeout=5
        )
        workspaces = json.loads(result.stdout)
    except Exception:
        workspaces = []

    # Query niri for windows
    try:
        result = subprocess.run(
            ["niri", "msg", "--json", "windows"],
            capture_output=True, text=True, timeout=5
        )
        windows = json.loads(result.stdout)
    except Exception:
        windows = []

    # Screenshot each output with grim
    for output_name, output_info in outputs.items():
        thumb_path = THUMB_DIR / f"{output_name}.png"
        try:
            subprocess.run(
                ["grim", "-o", output_name, str(thumb_path)],
                capture_output=True, timeout=10
            )
        except Exception:
            pass

    # Build workspace entries with window metadata
    entries = []
    for ws in workspaces:
        ws_id = ws.get("id", 0)
        ws_idx = ws.get("idx", 0)
        ws_name = ws.get("name") or ""
        ws_output = ws.get("output", "")
        ws_active = ws.get("is_active", False)
        is_focused = ws.get("is_focused", False)

        ws_windows = []
        for w in windows:
            if w.get("workspace_id") == ws_id:
                ws_windows.append({
                    "id": w.get("id", 0),
                    "title": w.get("title", ""),
                    "app_id": w.get("app_id", ""),
                    "is_focused": w.get("is_focused", False),
                })

        thumb = str(THUMB_DIR / f"{ws_output}.png")
        if not os.path.isfile(thumb):
            thumb = ""

        entry = {
            "wsId": ws_id,
            "wsIdx": ws_idx,
            "wsName": ws_name,
            "output": ws_output,
            "isActive": ws_active,
            "isFocused": is_focused,
            "thumb": thumb,
            "windowCount": len(ws_windows),
            "windows": ws_windows,
        }
        entries.append(entry)

    # Sort by output then index and output JSONL
    entries.sort(key=lambda e: (e["output"], e["wsIdx"]))

    for entry in entries:
        print(json.dumps(entry), flush=True)

    print("done", flush=True)


if __name__ == "__main__":
    main()
